modules = ["nodejs-20", "web", "python-3.12", "bash", "postgresql-16"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "NODE_ENV=development node_modules/.bin/tsx server/_core/index.ts"
waitForPort = 5000

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3000

[[ports]]
localPort = 5002
externalPort = 3002

[deployment]
deploymentTarget = "autoscale"
run = ["node", "dist/index.js"]
build = ["npm", "run", "build"]

[userenv]

[userenv.shared]
VITE_APP_ID = "41441854-d220-4390-8b57-240072bee172"
GMAIL_FROM_EMAIL = "fleetwizards.app@gmail.com"
